PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/team-task-manager
JWT_SECRET=change-this-to-a-long-random-string
# CORS: comma-separated origins. For combined Docker / single-host deploy, set to your public site URL (same as the browser origin), or omit in production to allow reflecting the request origin.
CLIENT_URL=http://localhost:5173

# Optional: MongoDB server selection timeout (ms). Default 45000 in config/db.js
# MONGO_SERVER_SELECTION_MS=60000

# Optional seed overrides (server/seed/seed.js)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=Admin123!
# SEED_MEMBER_EMAIL=member@example.com
# SEED_MEMBER_PASSWORD=Member123!
